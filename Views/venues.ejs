<!-- . Event Management Page (Admin Only)
o Allows administrators to create, update, view, and delete events (CRUD)
o Manages event capacity and availability
o Enforces authorization via middleware -->

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TicketStream | Venue Management</title>
  <link rel="stylesheet" href="/css/index.css">
  <link rel="stylesheet" href="/css/event.css">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="admin-body">
  <%- include('partials/header') %>

  <div class="admin-layout">

    <!-- Sidebar -->
    <aside class="venue-sidebar" id="venueSidebar">
      <div class="sidebar-header">
        <h3>Venues</h3>
        <button class="btn-add-venue" onclick="resetForm()">+ Add Venue</button>
      </div>
      <ul class="venue-list" id="venueList">
        <% if (venues && venues.length > 0) { %>
          <% venues.forEach(function(venue) { %>
            <li class="venue-list-item" onclick="loadVenue('<%= venue._id %>')" data-id="<%= venue._id %>">
              <span class="venue-list-address"><%= venue.name %></span>
              <span class="venue-list-city"><%= venue.address1 %> · <%= venue.zip %></span>
            </li>
          <% }) %>
        <% } else { %>
          <li class="venue-list-empty">No venues yet</li>
        <% } %>
      </ul>
    </aside>

    <!-- Main content -->
    <main class="admin-main">
      <div class="admin-page-header">
        <h1 id="formTitle">Add New Venue</h1>
        <p id="formSubtitle">Fill in the details below to add a new venue</p>
      </div>

      <form id="venueForm" class="admin-form" onsubmit="submitVenue(event)">
        <input type="hidden" id="venueId" value="">

        <!-- Basic details -->
        <div class="form-section">
          <h2 class="form-section-title">Venue Details</h2>
          <div class="form-grid">
            <div class="form-group full-width">
              <label for="name">Venue Name *</label>
              <input type="text" id="name" name="name" placeholder="e.g. Pretoria State Theatre" required>
            </div>
            <div class="form-group">
              <label for="address1">Address Line 1 *</label>
              <input type="text" id="address1" name="address1" placeholder="12 Main Street" required>
            </div>
            <div class="form-group">
              <label for="address2">Address Line 2</label>
              <input type="text" id="address2" name="address2" placeholder="Suite 4B">
            </div>
            <div class="form-group">
              <label for="zip">Zip Code *</label>
              <input type="text" id="zip" name="zip" placeholder="0001" required>
            </div>
            <div class="form-group">
              <label for="totalSeats">Total Capacity *</label>
              <input type="number" id="totalSeats" name="totalSeats" placeholder="500" min="1" required>
            </div>
          </div>
          <div class="form-group full-width">
            <label for="layoutImage">Venue Layout Image</label>
            <input type="file" id="layoutImage" name="layoutImage" accept="image/*">
            <div id="imagePreview" class="image-preview" style="display:none;">
              <img id="previewImg" src="" alt="Layout preview">
            </div>
          </div>
        </div>

        <!-- Seating options -->
        <div class="form-section">
          <h2 class="form-section-title">Seating Configuration</h2>
          <div class="seating-toggle">
            <label class="checkbox-label">
              <input type="checkbox" id="customSeating" onchange="toggleCustomSeating()">
              <span class="checkbox-custom"></span>
              Define custom seating layout
            </label>
            <p class="toggle-hint">Leave unchecked if seating is assigned at the door</p>
          </div>

          <!-- Custom seating panel -->
          <div id="customSeatingPanel" style="display:none;">
            <div class="block-generator">
              <div class="form-group">
                <label for="numBlocks">Number of Blocks</label>
                <div class="input-btn-row">
                  <input type="number" id="numBlocks" placeholder="e.g. 3" min="1" max="20">
                  <button type="button" class="btn-generate" onclick="generateBlocks()">Generate Blocks</button>
                </div>
              </div>
            </div>
            <div id="blocksContainer"></div>
          </div>
        </div>

        <!-- Form actions -->
        <div class="form-actions">
          <button type="submit" class="btn-primary" id="submitBtn">Add Venue</button>
          <button type="button" class="btn-secondary" id="clearBtn" onclick="resetForm()">Clear</button>
          <button type="button" class="btn-danger" id="deleteBtn" style="display:none;" onclick="deleteVenue()">Delete Venue</button>
        </div>
      </form>
    </main>
  </div>

  <!-- Confirm delete modal -->
  <div class="modal-overlay" id="confirmModal" style="display:none;">
    <div class="modal">
      <h3>Delete Venue</h3>
      <p>Are you sure you want to delete this venue? This action cannot be undone.</p>
      <div class="modal-actions">
        <button class="btn-danger" onclick="confirmDelete()">Yes, Delete</button>
        <button class="btn-secondary" onclick="closeModal()">Cancel</button>
      </div>
    </div>
  </div>
  <%- include('partials/footer') %>
</body>
</html>

  <!-- Inline venue data for JS -->
  <script>
    const existingVenues = <%- JSON.stringify(venues || []) %>;
  </script>
  <script src="/js/venues.js"></script>
</body>
</html>