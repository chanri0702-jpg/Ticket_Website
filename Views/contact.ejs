<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Support</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/contact.css">
</head>
<body>
  <%- include('partials/header') %>

  <div class="contact-container">
      <h2>How can we help?</h2>
      <p style="text-align: center; color: var(--light-text); margin-bottom: 2rem;">Send us your enquiry and our team will get back to you.</p>
      
      <form id="contactForm" class="contact-form">
          <div class="form-group">
              <label for="email">Email Address</label>
              <input type="email" id="email" required placeholder="you@example.com">
          </div>

          <div class="form-group">
              <label for="subject">Subject</label>
              <input type="text" id="subject" required placeholder="What is this regarding?">
          </div>

          <div class="form-group">
              <label for="message">Your Message</label>
              <textarea id="message" rows="5" required placeholder="Type your message here..."></textarea>
          </div>

          <button type="submit" class="btn-submit">Submit Enquiry</button>
      </form>
  </div>

  <%- include('partials/footer') %>
  <script src="/js/contact.js"></script>
</body>
</html>