<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TicketStream | Event Management</title>
  <link rel="stylesheet" href="/css/index.css">
  <link rel="stylesheet" href="/css/event.css">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="admin-body">

  <nav>
    <a href="/" class="logo">TICKETSTREAM</a>
    <ul class="nav-links">
      <li><a href="/">Events</a></li>
      <li><a href="/contact">Support</a></li>
      <li class="dropdown">
        <a href="#" class="dropdown-toggle">Event Management ▾</a>
        <ul class="dropdown-menu">
          <li><a href="venues">Manage Venues</a></li>
          <li><a href="events">Manage Events</a></li>
          <li><a href="times-admin">Manage Times</a></li>
        </ul>
      </li>
      <li><a href="/login" class="btn-login">Login</a></li>
    </ul>
  </nav>

  <div class="admin-layout">

    <aside class="venue-sidebar" id="eventSidebar">
      <div class="sidebar-header">
        <h3>Events</h3>
        <button class="btn-add-venue" onclick="resetForm()">+ Add Event</button>
      </div>
      <ul class="venue-list" id="eventList">
        <% if (events && events.length > 0) { %>
          <% events.forEach(function(event) { %>
            <li class="venue-list-item" onclick="loadEvent('<%= event._id %>')" data-id="<%= event._id %>">
              <span class="venue-list-address"><%= event.name %></span>
              <span class="venue-list-city"><%= event.category %></span>
            </li>
          <% }) %>
        <% } else { %>
          <li class="venue-list-empty">No events yet</li>
        <% } %>
      </ul>
    </aside>

    <main class="admin-main">
      <div class="admin-page-header">
        <h1 id="formTitle">Add New Event</h1>
        <p id="formSubtitle">Fill in the details below to add a new event</p>
      </div>

      <form id="eventForm" class="admin-form" onsubmit="submitEvent(event)">
        <input type="hidden" id="eventId" value="">
        <div class="form-section">
          <h2 class="form-section-title">Event Details</h2>
          <div class="form-grid">
            <div class="form-group full-width">
              <label for="name">Event Name *</label>
              <input type="text" id="name" name="name" placeholder="e.g. Jazz Night Live" required>
            </div>
            <div class="form-group full-width">
              <label for="description">Description</label>
              <textarea id="description" name="description" placeholder="Describe the event..." rows="3"></textarea>
            </div>
            <div class="form-group">
              <label for="host">Host / Organiser</label>
              <input type="text" id="host" name="host" placeholder="e.g. Pretoria Arts Council">
            </div>
            <div class="form-group">
              <label for="category">Category *</label>
              <select id="category" name="category" required>
                <option value="">Select a category</option>
                <option value="Concert">Concert</option>
                <option value="Sports">Sports</option>
                <option value="Theater">Theater</option>
                <option value="Conference">Conference</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="venueID">Venue *</label>
              <select id="venueID" name="venueID" required onchange="onVenueChange()">
                <option value="">Select a venue</option>
                <% if (venues && venues.length > 0) { %>
                  <% venues.forEach(function(venue) { %>
                    <option value="<%= venue._id %>"><%= venue.name %> — <%= venue.address1 %></option>
                  <% }) %>
                <% } %>
              </select>
            </div>
            <div class="form-group full-width">
              <label for="image">Event Image URL</label>
              <input type="text" id="image" name="image" placeholder="/images/events/my-event.png">
              <div id="imagePreview" class="image-preview" style="display:none;">
                <img id="previewImg" src="" alt="Event image preview">
              </div>
            </div>
          </div>
        </div>

        <div class="form-section">
          <h2 class="form-section-title">Pricing</h2>

          <div class="form-group" style="margin-bottom: 1.25rem;">
            <label>Price Type</label>
            <div class="radio-group">
              <label class="radio-label">
                <input type="radio" name="priceType" value="uniform" checked onchange="togglePricing('uniform')">
                Uniform Price
              </label>
              <label class="radio-label">
                <input type="radio" name="priceType" value="custom" onchange="togglePricing('custom')">
                Custom Price per Block
              </label>
            </div>
          </div>

          <div id="uniformPricing">
            <div class="form-group">
              <label for="price">Ticket Price (R) *</label>
              <input type="number" id="price" name="price" placeholder="e.g. 250" min="0" step="0.01">
            </div>
          </div>

          <div id="customPricing" style="display:none;">
            <p class="toggle-hint" style="margin-bottom: 1rem;">
              Select a venue with a seating layout to configure block prices.
            </p>
            <div id="blockPriceInputs" class="rows-config"></div>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-primary" id="submitBtn">Add Event</button>
          <button type="button" class="btn-secondary" id="clearBtn" onclick="resetForm()">Clear</button>
          <button type="button" class="btn-danger" id="deleteBtn" style="display:none;" onclick="deleteEvent()">Delete Event</button>
        </div>
      </form>
    </main>
  </div>

  <div class="modal-overlay" id="confirmModal" style="display:none;">
    <div class="modal">
      <h3>Delete Event</h3>
      <p>Are you sure you want to delete this event? This action cannot be undone.</p>
      <div class="modal-actions">
        <button class="btn-danger" onclick="confirmDelete()">Yes, Delete</button>
        <button class="btn-secondary" onclick="closeModal()">Cancel</button>
      </div>
    </div>
  </div>

  <script>
    const existingEvents = <%- JSON.stringify(events || []) %>;
    const existingVenues = <%- JSON.stringify(venues || []) %>;
  </script>
  <script src="/js/events.js"></script>
</body>
</html>